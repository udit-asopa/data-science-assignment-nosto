    "\n",
    "# segment-aware baseline: median per (ever_bought × start_dayofweek)\n",
    "seg_medians = (\n",
    "    train_df.groupby([\"ever_bought\", \"start_dayofweek\"])[\"return_hours\"]\n",
    "    .median()\n",
    "    .rename(\"seg_median\")\n",
